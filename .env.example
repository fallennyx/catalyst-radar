# Catalyst Radar — environment template
# Copy to .env (which is gitignored) and fill in real values.

# LLM provider (primary). Free tier 1500 req/day at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# LLM provider (fallback). Used when LLM_PROVIDER="anthropic" in radar/config.py.
ANTHROPIC_API_KEY=

# Telegram alert channel — DM @BotFather to create a bot, get chat ID via getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Lighter mainnet API. Public market data is free/no-key; key is needed only for
# user-authenticated operations (currently unused — universe + orderbook reads are public).
LIGHTER_API_KEY=
